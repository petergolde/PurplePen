    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="lcmsNET" Version="1.2.1" />
  </ItemGroup>

  <ItemGroup>
    <None Update="GRACoL2013UNC_CRPC3.icc">
