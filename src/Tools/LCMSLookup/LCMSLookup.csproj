    </None>
    <None Update="GRACoL2013_CRPC6.icc">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="USWebCoatedSWOP.icc">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Native\LittleCMS-LICENSE.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>LittleCMS-LICENSE.txt</TargetPath>
    </None>
    <None Update="Native\win-x64\lcms2.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>lcms2.dll</TargetPath>
    </None>
