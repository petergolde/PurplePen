<!--
    MainWindow.axaml
    Main application window for Purple Pen.
    Migrated from WinForms PurplePen/MainFrame.cs.

    Layout structure:
      DockPanel (root)
        ├── Menu (mainMenu) — docked Top
        ├── Toolbar panel — docked Top
        ├── TabControl (courseTabs) — docked Top
        ├── Status bar Grid — docked Bottom
        └── Main content Grid with GridSplitter — fills remaining space
              ├── Left panel (splitDescription equivalent)
              │     ├── Description/Topology area with radio buttons
              │     ├── GridSplitter (horizontal)
              │     └── Selection panel
              └── Right panel
                    ├── coursePartBanner (top)
                    └── Map viewer with scroll bars
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:views="using:AvPurplePen"
        xmlns:avutil="using:AvUtil"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="958" d:DesignHeight="600"
        x:Class="AvPurplePen.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/PurplePenIcon.png"
        Title="{resx:Localize MainFrame_Text}"
        MapMousePointerShape="{Binding MapMousePointerShape}"
        >

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding FileOpenPurplePenFileCommand}"/>
        <KeyBinding Gesture="F4" Command="{Binding ToggleAllControlsCommand}"/>
    </Window.KeyBindings>

    <DockPanel LastChildFill="True">

        <!-- ==================== MAIN MENU ==================== -->
        <Menu x:Name="mainMenu" DockPanel.Dock="Top">

            <!-- === File Menu === -->
            <MenuItem x:Name="fileMenu" Header="{resx:Localize MainFrame_fileMenu_Text}">
                <MenuItem x:Name="newEventMenu" Header="{resx:Localize MainFrame_newEventMenu_Text}" Command="{Binding NewEventCommand}"/>
                <MenuItem x:Name="openMenu" Header="{resx:Localize MainFrame_openMenu_Text}" InputGesture="Ctrl+O" Command="{Binding FileOpenPurplePenFileCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/open.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="saveMenu" Header="{resx:Localize MainFrame_saveMenu_Text}" InputGesture="Ctrl+S" Command="{Binding SaveCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/save.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="saveAsMenu" Header="{resx:Localize MainFrame_saveAsMenu_Text}" Command="{Binding SaveAsCommand}"/>
                <Separator/>
                <MenuItem x:Name="createOcadFilesMenu" Header="{resx:Localize MainFrame_createOcadFilesMenu_Text}" Command="{Binding CreateOcadFilesCommand}"/>
                <MenuItem x:Name="createImageFilesMenu" Header="{resx:Localize MainFrame_createImageFilesMenu_Text}" Command="{Binding CreateImageFilesCommand}"/>
                <MenuItem x:Name="createPDFsMenu" Header="{resx:Localize MainFrame_createPDFsMenu_Text}">
                    <MenuItem x:Name="createDescriptionPdfMenu" Header="{resx:Localize MainFrame_createDescriptionPdfMenu_Text}" Command="{Binding CreateDescriptionPdfCommand}"/>
                    <MenuItem x:Name="createPunchcardPdfMenu" Header="{resx:Localize MainFrame_createPunchcardPdfMenu_Text}" Command="{Binding CreatePunchcardPdfCommand}"/>
                    <MenuItem x:Name="createCoursePdfMenu" Header="{resx:Localize MainFrame_createCoursePdfMenu_Text}" Command="{Binding CreateCoursePdfCommand}"/>
                </MenuItem>
                <MenuItem x:Name="createRouteReviewFilesToolStripMenuItem" Header="{resx:Localize MainFrame_createRouteReviewFilesToolStripMenuItem_Text}">
                    <MenuItem x:Name="createRouteGadgetFilesMenu" Header="{resx:Localize MainFrame_createRouteGadgetFilesMenu_Text}" Command="{Binding CreateRouteGadgetFilesCommand}"/>
                </MenuItem>
                <MenuItem x:Name="createXmlMenu" Header="{resx:Localize MainFrame_createXmlMenu_Text}" Command="{Binding CreateXmlCommand}"/>
                <MenuItem x:Name="createGPXFileMenu" Header="{resx:Localize MainFrame_createGPXFileMenu_Text}" Command="{Binding CreateGpxCommand}"/>
                <MenuItem x:Name="createKMLFileMenu" Header="{resx:Localize MainFrame_createKMLFileMenu_Text}" Command="{Binding CreateKmlFilesCommand}"/>
                <Separator/>
                <MenuItem x:Name="printDescriptionsMenu" Header="{resx:Localize MainFrame_printDescriptionsMenu_Text}" InputGesture="Ctrl+P" Command="{Binding PrintDescriptionsCommand}"/>
                <MenuItem x:Name="printPunchCardsMenu" Header="{resx:Localize MainFrame_printPunchCardsMenu_Text}" Command="{Binding PrintPunchCardsCommand}"/>
                <MenuItem x:Name="printCoursesMenu" Header="{resx:Localize MainFrame_printCoursesMenu_Text}" Command="{Binding PrintCoursesCommand}"/>
                <MenuItem x:Name="setPrintAreaMenu" Header="{resx:Localize MainFrame_setPrintAreaMenu_Text}">
                    <MenuItem x:Name="printAreaThisPartMenu" Header="{resx:Localize MainFrame_printAreaThisPartMenu_Text}" Command="{Binding SetPrintAreaThisPartCommand}"/>
                    <MenuItem x:Name="printAreaThisCourseMenu" Header="{resx:Localize MainFrame_printAreaThisCourseMenu_Text}" Command="{Binding SetPrintAreaThisCourseCommand}"/>
                    <MenuItem x:Name="printAreaAllCoursesMenu" Header="{resx:Localize MainFrame_printAreaAllCoursesMenu_Text}" Command="{Binding SetPrintAreaAllCoursesCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="programLanguageMenu" Header="{resx:Localize MainFrame_programLanguageMenu_Text}"
                          Command="{Binding ShowSwitchLanguageDialogCommand}"/>
                <Separator/>
                <MenuItem x:Name="exitMenu" Header="{resx:Localize MainFrame_exitMenu_Text}" Command="{Binding ExitCommand}"/>
            </MenuItem>

            <!-- === Edit Menu === -->
            <MenuItem x:Name="editMenu" Header="{resx:Localize MainFrame_editMenu_Text}">
                <MenuItem x:Name="cancelMenu" Header="{resx:Localize MainFrame_cancelMenu_Text}" Command="{Binding CancelCommand}"/>
                <Separator/>
                <MenuItem x:Name="undoMenu" Header="{resx:Localize MainFrame_undoMenu_Text}" InputGesture="Ctrl+Z" Command="{Binding UndoCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/undo.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="redoMenu" Header="{resx:Localize MainFrame_redoMenu_Text}" InputGesture="Ctrl+Y" Command="{Binding RedoCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/redo.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="deleteMenu" Header="{resx:Localize MainFrame_deleteMenu_Text}" InputGesture="Delete" Command="{Binding DeleteSelectionCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/delete.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- === View Menu === -->
            <MenuItem x:Name="viewMenu" Header="{resx:Localize MainFrame_viewMenu_Text}">
                <MenuItem x:Name="entireCourseMenu" Header="{resx:Localize MainFrame_entireCourseMenu_Text}" InputGesture="F2" Command="{Binding ViewEntireCourseCommand}"/>
                <MenuItem x:Name="entireMapMenu" Header="{resx:Localize MainFrame_entireMapMenu_Text}" InputGesture="F3" Command="{Binding ViewEntireMapCommand}"/>
                <MenuItem x:Name="zoomMenu" Header="{resx:Localize MainFrame_zoomMenu_Text}">
                    <MenuItem x:Name="zoom50Menu" Header="{resx:Localize MainFrame_zoom50Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=0.5, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom50Checked}"/>
                    <MenuItem x:Name="zoom100Menu" Header="{resx:Localize MainFrame_zoom100Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=1, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom100Checked}"/>
                    <MenuItem x:Name="zoom150Menu" Header="{resx:Localize MainFrame_zoom150Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=1.5, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom150Checked}"/>
                    <MenuItem x:Name="zoom200Menu" Header="{resx:Localize MainFrame_zoom200Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=2, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom200Checked}"/>
                    <MenuItem x:Name="zoom300Menu" Header="{resx:Localize MainFrame_zoom300Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=3, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom300Checked}"/>
                    <MenuItem x:Name="zoom500Menu" Header="{resx:Localize MainFrame_zoom500Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=5, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom500Checked}"/>
                    <MenuItem x:Name="zoom1000Menu" Header="{resx:Localize MainFrame_zoom1000Menu_Text}" Command="{Binding SetZoomCommand}"
                              CommandParameter="{Binding Source=10, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding Zoom1000Checked}"/>
                </MenuItem>

                <Separator/>

                <MenuItem x:Name="mapIntensityMenu" Header="{resx:Localize MainFrame_mapIntensityMenu_Text}">
                    <MenuItem x:Name="veryLowIntensityMenu" Header="{resx:Localize MainFrame_veryLowIntensityMenu_Text}" Command="{Binding SetMapIntensityCommand}"
                              CommandParameter="{Binding Source=0.2, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding IntensityVeryLowChecked}"/>
                    <MenuItem x:Name="lowIntensityMenu" Header="{resx:Localize MainFrame_lowIntensityMenu_Text}" Command="{Binding SetMapIntensityCommand}"
                              CommandParameter="{Binding Source=0.4, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding IntensityLowChecked}"/>
                    <MenuItem x:Name="mediumIntensityMenu" Header="{resx:Localize MainFrame_mediumIntensityMenu_Text}" Command="{Binding SetMapIntensityCommand}"
                              CommandParameter="{Binding Source=0.6, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding IntensityMediumChecked}"/>
                    <MenuItem x:Name="highIntensityMenu" Header="{resx:Localize MainFrame_highIntensityMenu_Text}" Command="{Binding SetMapIntensityCommand}"
                              CommandParameter="{Binding Source=0.8, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding IntensityHighChecked}"/>
                    <MenuItem x:Name="fullIntensityMenu" Header="{resx:Localize MainFrame_fullIntensityMenu_Text}" Command="{Binding SetMapIntensityCommand}"
                              CommandParameter="{Binding Source=1, Converter={x:Static avutil:StringToDoubleConverter.Instance}}"
                              ToggleType="CheckBox" IsChecked="{Binding IntensityFullChecked}"/>
                </MenuItem>

                <MenuItem x:Name="mapQualityMenu" Header="{resx:Localize MainFrame_mapQualityMenu_Text}">
                    <MenuItem x:Name="normalQualityMenu" Header="{resx:Localize MainFrame_normalQualityMenu_Text}" 
                              Command="{Binding SetNormalQualityCommand}"
                              ToggleType="CheckBox" IsChecked="{Binding !HighQualityMapDisplay}"/>
                    <MenuItem x:Name="highQualityMenu" Header="{resx:Localize MainFrame_highQualityMenu_Text}" 
                              Command="{Binding SetHighQualityCommand}"
                              ToggleType="CheckBox" IsChecked="{Binding HighQualityMapDisplay}"/>
                </MenuItem>

                <MenuItem x:Name="showPrintAreaMenu" Header="{resx:Localize MainFrame_showPrintAreaMenu_Text}" Command="{Binding ToggleShowPrintAreaCommand}"/>
                <MenuItem x:Name="showPopupsMenu" Header="{resx:Localize MainFrame_showPopupsMenu_Text}" Command="{Binding ToggleShowPopupsCommand}"/>

                <Separator/>

                <MenuItem x:Name="allControlsMenu" Header="{resx:Localize MainFrame_allControlsMenu_Text}" InputGesture="F4" 
                          Command="{Binding ToggleAllControlsCommand}"
                          ToggleType="CheckBox" IsChecked="{Binding ViewAllControlsChecked}"/>
                <MenuItem x:Name="otherCoursesMenu" Header="{resx:Localize MainFrame_otherCoursesMenu_Text}" 
                          InputGesture="F5" 
                          Command="{Binding ShowOtherCoursesCommand}"/>
                <MenuItem x:Name="clearOtherCoursesMenu" Header="{resx:Localize MainFrame_clearOtherCoursesMenu_Text}" 
                          IsVisible="{Binding IsVisibleClearOtherCourses}"
                          InputGesture="Shift+F5" 
                          Command="{Binding ClearOtherCoursesCommand}"/>
            </MenuItem>

            <!-- === Add Menu === -->
            <MenuItem x:Name="addMenu" Header="{resx:Localize MainFrame_addMenu_Text}">
                <MenuItem x:Name="addStartMenu" Header="{resx:Localize MainFrame_addStartMenu_Text}" Command="{Binding AddStartCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/addStart.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addControlMenu" Header="{resx:Localize MainFrame_addControlMenu_Text}" InputGesture="Ctrl+A" Command="{Binding AddControlCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/addControl.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addFinishMenu" Header="{resx:Localize MainFrame_addFinishMenu_Text}" Command="{Binding AddFinishCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/addFinish.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addDescriptionsMenu" Header="{resx:Localize MainFrame_addDescriptionsMenu_Text}" Command="{Binding AddDescriptionsCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/descriptionsItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addMapExchangeMenu" Header="{resx:Localize MainFrame_addMapExchangeMenu_Text}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/mapExchange.png" Width="16" Height="16"/></MenuItem.Icon>
                    <MenuItem x:Name="addMapFlipMenuItem" Header="{resx:Localize MainFrame_addMapFlipMenuItem_Text}" Command="{Binding AddMapFlipControlCommand}">
                        <MenuItem.Icon><Image Source="/Assets/Toolbar/mapFlipMenuItem.png" Width="16" Height="16"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mapExchangeControlMenuItem" Header="{resx:Localize MainFrame_mapExchangeControlMenuItem_Text}" Command="{Binding AddMapExchangeControlCommand}">
                        <MenuItem.Icon><Image Source="/Assets/Toolbar/mapExchangeControlItem.png" Width="16" Height="16"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="mapExchangeSeparateMenuItem" Header="{resx:Localize MainFrame_mapExchangeSeparateMenuItem_Text}" Command="{Binding AddMapExchangeSeparateCommand}">
                        <MenuItem.Icon><Image Source="/Assets/Toolbar/mapExchangeSeparateItem.png" Width="16" Height="16"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem x:Name="addVariationMenu" Header="{resx:Localize MainFrame_addVariationMenu_Text}" Command="{Binding AddVariationCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/addVariation.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addTextLineMenu" Header="{resx:Localize MainFrame_addTextLineMenu_Text}" Command="{Binding AddTextLineCommand}"/>
                <Separator/>
                <MenuItem x:Name="addMapIssueMenu" Header="{resx:Localize MainFrame_addMapIssueMenu_Text}" Command="{Binding AddMapIssueCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/mapIssuePointItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addMandatoryCrossingMenu" Header="{resx:Localize MainFrame_addMandatoryCrossingMenu_Text}" Command="{Binding AddMandatoryCrossingCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/mandatoryCrossingPointItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addOptCrossingMenu" Header="{resx:Localize MainFrame_addOptCrossingMenu_Text}" Command="{Binding AddOptCrossingCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/optionalCrossingPointItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addOutOfBoundsMenu" Header="{resx:Localize MainFrame_addOutOfBoundsMenu_Text}" Command="{Binding AddOutOfBoundsCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/outOfBoundsItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addDangerousMenu" Header="{resx:Localize MainFrame_addDangerousMenu_Text}" 
                          IsVisible="{Binding IsVisibleDangerousArea}"
                          Command="{Binding AddDangerousCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/dangerousItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addConstructionMenu" Header="{resx:Localize MainFrame_addConstructionMenu_Text}" Command="{Binding AddConstructionCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/constructionItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addWaterMenu" Header="{resx:Localize MainFrame_addWaterMenu_Text}" Command="{Binding AddWaterCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/waterLocationItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addFirstAidMenu" Header="{resx:Localize MainFrame_addFirstAidMenu_Text}" Command="{Binding AddFirstAidCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/firstAidLocationItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addForbiddenMenu" Header="{resx:Localize MainFrame_addForbiddenMenu_Text}" Command="{Binding AddForbiddenCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/forbiddenRouteMarkingItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addBoundaryMenu" Header="{resx:Localize MainFrame_addBoundaryMenu_Text}" Command="{Binding AddBoundaryCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/boundaryItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addRegMarkMenu" Header="{resx:Localize MainFrame_addRegMarkMenu_Text}" Command="{Binding AddRegMarkCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/registrationMarkItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="whiteOutMenu" Header="{resx:Localize MainFrame_whiteOutMenu_Text}" Command="{Binding AddWhiteOutCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/whiteOutItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addTextMenu" Header="{resx:Localize MainFrame_addTextMenu_Text}" Command="{Binding AddTextCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/textItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addImageMenu" Header="{resx:Localize MainFrame_addImageMenu_Text}" Command="{Binding AddImageCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/imageItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addLineMenu" Header="{resx:Localize MainFrame_addLineMenu_Text}" Command="{Binding AddLineCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/lineItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addRectangleMenu" Header="{resx:Localize MainFrame_addRectangleMenu_Text}" Command="{Binding AddRectangleCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/rectangleItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="addEllipseMenu" Header="{resx:Localize MainFrame_addEllipseMenu_Text}" Command="{Binding AddEllipseCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/ellipseItem.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- === Event Menu === -->
            <MenuItem x:Name="eventMenu" Header="{resx:Localize MainFrame_eventMenu_Text}">
                <MenuItem x:Name="changeMapFileMenu" Header="{resx:Localize MainFrame_changeMapFileMenu_Text}" Command="{Binding ChangeMapFileCommand}"/>
                <Separator/>
                <MenuItem x:Name="changeCodesMenu" Header="{resx:Localize MainFrame_changeCodesMenu_Text}" Command="{Binding ChangeCodesCommand}"/>
                <MenuItem x:Name="autoNumberingMenu" Header="{resx:Localize MainFrame_autoNumberingMenu_Text}" Command="{Binding AutoNumberingCommand}"/>
                <MenuItem x:Name="removeUnusedControlsMenu" Header="{resx:Localize MainFrame_removeUnusedControlsMenu_Text}" Command="{Binding RemoveUnusedControlsCommand}"/>
                <MenuItem x:Name="moveAllControlsMenu" Header="{resx:Localize MainFrame_moveAllControlsMenu_Text}" Command="{Binding MoveAllControlsCommand}"/>
                <Separator/>
                <MenuItem x:Name="punchPatternsMenu" Header="{resx:Localize MainFrame_punchPatternsMenu_Text}" Command="{Binding PunchPatternsCommand}"/>
                <Separator/>
                <MenuItem x:Name="iOFStandardsToolStripMenuItem" Header="{resx:Localize MainFrame_iOFStandardsToolStripMenuItem_Text}">
                    <MenuItem x:Name="descriptionStd2004Menu" Header="{resx:Localize MainFrame_descriptionStd2004Menu_Text}" 
                              ToggleType="CheckBox" IsChecked="{Binding DescriptionStd2004Checked}"
                              Command="{Binding SetDescriptionStd2004Command}"/>
                    <MenuItem x:Name="descriptionStd2018Menu" Header="{resx:Localize MainFrame_descriptionStd2018Menu_Text}" 
                              ToggleType="CheckBox" IsChecked="{Binding DescriptionStd2018Checked}"
                              Command="{Binding SetDescriptionStd2018Command}"/>
                    <Separator/>
                    <MenuItem x:Name="mapStd2000Menu" Header="{resx:Localize MainFrame_mapStd2000Menu_Text}" 
                              ToggleType="CheckBox" IsChecked="{Binding MapStd2000Checked}"
                              Command="{Binding SetMapStd2000Command}"/>
                    <MenuItem x:Name="mapStd2017Menu" Header="{resx:Localize MainFrame_mapStd2017Menu_Text}" 
                              ToggleType="CheckBox" IsChecked="{Binding MapStd2017Checked}"
                              Command="{Binding SetMapStd2017Command}"/>
                    <MenuItem x:Name="mapStdSpr2019Menu" Header="{resx:Localize MainFrame_mapStdSpr2019Menu_Text}" 
                              ToggleType="CheckBox" IsChecked="{Binding MapStdSpr2019Checked}"
                              Command="{Binding SetMapStdSpr2019Command}"/>
                </MenuItem>
                <MenuItem x:Name="customizeDescriptionsMenu" Header="{resx:Localize MainFrame_customizeDescriptionsMenu_Text}" Command="{Binding CustomizeDescriptionsCommand}"/>
                <MenuItem x:Name="customizeCourseAppearanceMenu" Header="{resx:Localize MainFrame_customizeCourseAppearanceMenu_Text}" Command="{Binding CustomizeCourseAppearanceCommand}"/>
            </MenuItem>

            <!-- === Course Menu === -->
            <MenuItem x:Name="courseMenu" Header="{resx:Localize MainFrame_courseMenu_Text}">
                <MenuItem x:Name="addCourseMenu" Header="{resx:Localize MainFrame_addCourseMenu_Text}" Command="{Binding ShowAddCourseDialogCommand}"/>
                <MenuItem x:Name="deleteCourseMenu" Header="{resx:Localize MainFrame_deleteCourseMenu_Text}" Command="{Binding DeleteCourseCommand}"/>
                <MenuItem x:Name="duplicateCourseMenu" Header="{resx:Localize MainFrame_duplicateCourseMenu_Text}" Command="{Binding DuplicateCourseCommand}"/>
                <MenuItem x:Name="propertiesMenu" Header="{resx:Localize MainFrame_propertiesMenu_Text}" Command="{Binding ShowCoursePropertiesCommand}"/>
                <Separator/>
                <MenuItem x:Name="courseOrderMenu" Header="{resx:Localize MainFrame_courseOrderMenu_Text}" Command="{Binding ShowCourseOrderCommand}"/>
                <MenuItem x:Name="courseLoadMenu" Header="{resx:Localize MainFrame_courseLoadMenu_Text}" Command="{Binding ShowCourseLoadCommand}"/>
                <Separator/>
                <MenuItem x:Name="courseVariationReportMenu" Header="{resx:Localize MainFrame_courseVariationReportMenu_Text}" Command="{Binding ShowCourseVariationReportCommand}"/>
            </MenuItem>

            <!-- === Item Menu === -->
            <MenuItem x:Name="itemMenu" Header="{resx:Localize MainFrame_itemMenu_Text}">
                <MenuItem x:Name="deleteItemMenu" Header="{resx:Localize MainFrame_deleteItemMenu_Text}" InputGesture="Delete"
                          Command="{Binding DeleteSelectionCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/delete.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="deleteForkMenu" Header="{resx:Localize MainFrame_deleteForkMenu_Text}"
                          Command="{Binding DeleteForkCommand}"/>
                <Separator/>
                <MenuItem x:Name="addBendMenu" Header="{resx:Localize MainFrame_addBendMenu_Text}" 
                          InputGesture="Ctrl+B" Command="{Binding AddBendCommand}">
                    <MenuItem.Icon><Image Width="16" Height="16"
                       Source="{Binding IsEffectivelyEnabled,
                                RelativeSource={RelativeSource Self},
                                Converter={x:Static avutil:DisabledImageConverter.Instance},
                                ConverterParameter=/Assets/Toolbar/addBend.png}"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="removeBendMenu" Header="{resx:Localize MainFrame_removeBendMenu_Text}" InputGesture="Ctrl+Shift+B"
                          Command="{Binding RemoveBendCommand}"/>
                <MenuItem x:Name="addGapMenu" Header="{resx:Localize MainFrame_addGapMenu_Text}" InputGesture="Ctrl+G"
                          Command="{Binding AddGapCommand}">
                    <MenuItem.Icon><Image Source="/Assets/Toolbar/addGap.png" Width="16" Height="16"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="removeGapMenu" Header="{resx:Localize MainFrame_removeGapMenu_Text}" InputGesture="Ctrl+Shift+G"
                          Command="{Binding RemoveGapCommand}"/>
                <Separator/>
                <MenuItem x:Name="changeTextMenu" Header="{resx:Localize MainFrame_changeTextMenu_Text}"
                          Command="{Binding ChangeTextCommand}"/>
                <MenuItem x:Name="changeLineAppearanceMenu" Header="{resx:Localize MainFrame_changeLineAppearanceMenu_Text}"
                          Command="{Binding ChangeLineAppearanceCommand}"/>
                <MenuItem x:Name="rotateMenu" Header="{resx:Localize MainFrame_rotateMenu_Text}"
                          Command="{Binding RotateCommand}"/>
                <MenuItem x:Name="stretchMenu" Header="{resx:Localize MainFrame_stretchMenu_Text}"
                          Command="{Binding StretchCommand}"/>
                <MenuItem x:Name="legFlaggingMenu" Header="{resx:Localize MainFrame_legFlaggingMenu_Text}"
                          IsEnabled="{Binding CanSetLegFlagging}">
                    <MenuItem x:Name="noFlaggingMenu" Header="{resx:Localize MainFrame_noFlaggingMenu_Text}"
                              ToggleType="CheckBox" IsChecked="{Binding NoFlaggingChecked}"
                              Command="{Binding SetNoFlaggingCommand}"/>
                    <MenuItem x:Name="entireFlaggingMenu" Header="{resx:Localize MainFrame_entireFlaggingMenu_Text}"
                              ToggleType="CheckBox" IsChecked="{Binding EntireFlaggingChecked}"
                              Command="{Binding SetEntireFlaggingCommand}"/>
                    <MenuItem x:Name="beginFlaggingMenu" Header="{resx:Localize MainFrame_beginFlaggingMenu_Text}"
                              ToggleType="CheckBox" IsChecked="{Binding BeginFlaggingChecked}"
                              Command="{Binding SetBeginFlaggingCommand}"/>
                    <MenuItem x:Name="endFlaggingMenu" Header="{resx:Localize MainFrame_endFlaggingMenu_Text}"
                              ToggleType="CheckBox" IsChecked="{Binding EndFlaggingChecked}"
                              Command="{Binding SetEndFlaggingCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="changeDisplayedCoursesMenu" Header="{resx:Localize MainFrame_changeDisplayedCoursesMenu_Text}"
                          Command="{Binding ChangeDisplayedCoursesCommand}"/>
            </MenuItem>

            <!-- === Reports Menu === -->
            <MenuItem x:Name="reportMenu" Header="{resx:Localize MainFrame_reportMenu_Text}">
                <MenuItem x:Name="courseSummaryMenu" Header="{resx:Localize MainFrame_courseSummaryMenu_Text}"
                          Command="{Binding ShowCourseSummaryCommand}"/>
                <MenuItem x:Name="eventAuditMenu" Header="{resx:Localize MainFrame_eventAuditMenu_Text}"
                          Command="{Binding ShowEventAuditCommand}"/>
                <MenuItem x:Name="legLengthsMenu" Header="{resx:Localize MainFrame_legLengthsMenu_Text}"
                          Command="{Binding ShowLegLengthsCommand}"/>
                <MenuItem x:Name="controlCrossrefMenu" Header="{resx:Localize MainFrame_controlCrossrefMenu_Text}"
                          Command="{Binding ShowControlCrossrefCommand}"/>
                <MenuItem x:Name="controlAndLegLoadMenu" Header="{resx:Localize MainFrame_controlAndLegLoadMenu_Text}"
                          Command="{Binding ShowControlAndLegLoadCommand}"/>
            </MenuItem>

            <!-- === Help Menu === -->
            <MenuItem x:Name="helpMenu" Header="{resx:Localize MainFrame_helpMenu_Text}">
                <MenuItem x:Name="helpContentsMenu" Header="{resx:Localize MainFrame_helpContentsMenu_Text}" InputGesture="F1"
                          Command="{Binding HelpContentsCommand}"/>
                <MenuItem x:Name="helpTranslatedMenu" Header="{resx:Localize MainFrame_helpTranslatedMenu_Text}"
                          Command="{Binding HelpTranslatedCommand}"/>
                <Separator/>
                <MenuItem x:Name="mainWebSiteToolMenu" Header="{resx:Localize MainFrame_mainWebSiteToolMenu_Text}"
                          Command="{Binding OpenMainWebSiteCommand}"/>
                <MenuItem x:Name="supportWebSiteMenu" Header="{resx:Localize MainFrame_supportWebSiteMenu_Text}"
                          Command="{Binding OpenSupportWebSiteCommand}"/>
                <MenuItem x:Name="donateWebSiteMenu" Header="{resx:Localize MainFrame_donateWebSiteMenu_Text}"
                          Command="{Binding OpenDonateWebSiteCommand}"/>
                <Separator/>
                <MenuItem x:Name="aboutMenu" Header="{resx:Localize MainFrame_aboutMenu_Text}"
                          Command="{Binding ShowAboutDialogCommand}"/>
                <!-- Debug submenu — only visible in debug builds -->
                <MenuItem x:Name="debugMenu" Header="{resx:Localize MainFrame_debugMenu_Text}">
                    <MenuItem x:Name="symbolBrowserMenu" Header="{resx:Localize MainFrame_symbolBrowserMenu_Text}"
                              Command="{Binding ShowSymbolBrowserCommand}"/>
                    <MenuItem x:Name="descriptionBrowserMenu" Header="{resx:Localize MainFrame_descriptionBrowserMenu_Text}"
                              Command="{Binding ShowDescriptionBrowserCommand}"/>
                    <MenuItem x:Name="controlTesterMenu" Header="{resx:Localize MainFrame_controlTesterMenu_Text}"
                              Command="{Binding ShowControlTesterCommand}"/>
                    <MenuItem x:Name="mapTesterMenu" Header="{resx:Localize MainFrame_mapTesterMenu_Text}"
                              Command="{Binding ShowMapTesterCommand}"/>
                    <MenuItem x:Name="courseSelectorTesterMenu" Header="{resx:Localize MainFrame_courseSelectorTesterMenu_Text}"
                              Command="{Binding ShowCourseSelectorTesterCommand}"/>
                    <MenuItem x:Name="dotGridTesterToolStripMenuItem" Header="{resx:Localize MainFrame_dotGridTesterToolStripMenuItem_Text}"
                              Command="{Binding ShowDotGridTesterCommand}"/>
                    <MenuItem x:Name="dumpOCADFileMenu" Header="{resx:Localize MainFrame_dumpOCADFileMenu_Text}"
                              Command="{Binding DumpOcadFileCommand}"/>
                    <MenuItem x:Name="reportTesterToolStripMenuItem" Header="{resx:Localize MainFrame_reportTesterToolStripMenuItem_Text}"
                              Command="{Binding ShowReportTesterCommand}"/>
                    <MenuItem x:Name="fontMetricsToolStripMenuItem" Header="{resx:Localize MainFrame_fontMetricsToolStripMenuItem_Text}"
                              Command="{Binding ShowFontMetricsCommand}"/>
                    <MenuItem x:Name="missingTranslationsMenuItem" Header="{resx:Localize MainFrame_missingTranslationsMenuItem_Text}"
                              Command="{Binding ShowMissingTranslationsCommand}"/>
                    <MenuItem x:Name="crashToolStripMenuItem" Header="{resx:Localize MainFrame_crashToolStripMenuItem_Text}"
                              Command="{Binding TriggerCrashCommand}"/>
                    <MenuItem Header="MessageBox">
                        <MenuItem Header="OK" Command="{Binding TestMessageBoxOkCommand}"/>
                        <MenuItem Header="OK / Cancel" Command="{Binding TestMessageBoxOkCancelCommand}"/>
                        <MenuItem Header="Yes / No" Command="{Binding TestMessageBoxYesNoCommand}"/>
                        <MenuItem Header="Yes / No / Cancel" Command="{Binding TestMessageBoxYesNoCancelCommand}"/>
                    </MenuItem>
                </MenuItem>
                <!-- Translate submenu -->
                <MenuItem x:Name="translateMenu" Header="{resx:Localize MainFrame_translateMenu_Text}">
                    <MenuItem x:Name="addDescriptionLanguageMenu" Header="{resx:Localize MainFrame_addDescriptionLanguageMenu_Text}"
                              Command="{Binding AddDescriptionLanguageCommand}"/>
                    <MenuItem x:Name="addTranslatedTextsMenu" Header="{resx:Localize MainFrame_addTranslatedTextsMenu_Text}"
                              Command="{Binding AddTranslatedTextsCommand}"/>
                    <MenuItem x:Name="mergeSymbolsMenu" Header="{resx:Localize MainFrame_mergeSymbolsMenu_Text}"
                              Command="{Binding MergeSymbolsCommand}"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ==================== TOOLBAR ==================== -->
        <!-- Toolbar buttons arranged in a horizontal StackPanel.
             Image-only buttons show just an icon with a tooltip.
             Image+text buttons show icon and label side by side.
             Dropdown buttons use SplitButton with MenuFlyout. -->
        <StackPanel x:Name="toolbar" Classes="toolbar" DockPanel.Dock="Top" Orientation="Horizontal"
                    Spacing="2" Height="28">

            <!-- Open (image only) -->
            <Button x:Name="openToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_openToolStripButton_ToolTipText}"
                    Command="{Binding FileOpenPurplePenFileCommand}"
                    Padding="6,2,2,2">
                <Image Source="/Assets/Toolbar/open.png" Width="16" Height="16"/>
            </Button>

            <!-- Save (image only) -->
            <Button x:Name="saveToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_saveToolStripButton_ToolTipText}"
                    Command="{Binding SaveCommand}"
                    Padding="2,2">
                <Image Source="/Assets/Toolbar/save.png" Width="16" Height="16"/>
            </Button>
            <Separator Width="1" Margin="3,2"/>

            <!-- Undo (image only) -->
            <Button x:Name="undoToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_undoToolStripButton_ToolTipText}"
                    Command="{Binding UndoCommand}"
                    Padding="2,2">
                <Image Source="/Assets/Toolbar/undo.png" Width="16" Height="16"/>
            </Button>

            <!-- Redo (image only) -->
            <Button x:Name="redoToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_redoToolStripButton_ToolTipText}"
                    Command="{Binding RedoCommand}"
                    Padding="2,2">
                <Image Source="/Assets/Toolbar/redo.png" Width="16" Height="16"/>
            </Button>
            <Separator Width="1" Margin="4,2"/>

            <!-- Delete (image only) -->
            <Button x:Name="deleteToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_deleteToolStripButton_Text}"
                    Command="{Binding DeleteSelectionCommand}"
                    Padding="2,2">
                <Image Source="/Assets/Toolbar/delete.png" Width="16" Height="16"/>
            </Button>
            <Separator Width="1" Margin="2,2"/>

            <!-- Add Start (image + text) -->
            <Button x:Name="addStartToolStripButton" Padding="2,2"
                    Command="{Binding AddStartCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/addStart.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_addStartToolStripButton_Text}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Add Control (image + text) -->
            <Button x:Name="addControlToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_addControlToolStripButton_ToolTipText}"
                    Command="{Binding AddControlCommand}"
                    Padding="2,2">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/addControl.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_addControlToolStripButton_Text}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Add Finish (image + text) -->
            <Button x:Name="addFinishToolStripButton" Padding="2,2"
                    Command="{Binding AddFinishCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/addFinish.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_addFinishToolStripButton_Text}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Separator Width="1" Margin="2,2"/>

            <!-- Descriptions (image + text) -->
            <Button x:Name="descriptionsToolStripMenuItem" Padding="2,2"
                    Command="{Binding AddDescriptionsCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/descriptionsItem.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_descriptionsToolStripMenuItem_Text}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Map Exchange dropdown (image + text, click opens flyout menu) -->
            <Button x:Name="mapExchangeToolStripMenu" Padding="2,2"
                    IsEnabled="{Binding CanAddMapExchangeAny}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/mapExchange.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_mapExchangeToolStripMenu_Text}"
                               VerticalAlignment="Center"/>
                    <PathIcon Data="M1939 486L2029 576L1024 1581L19 576L109 486L1024 1401L1939 486Z"
                             Width="8" Height="8" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout  Placement="BottomEdgeAlignedLeft">
                        <MenuItem x:Name="mapFlipMenuItem" Header="{resx:Localize MainFrame_mapFlipMenuItem_Text}"
                                  Command="{Binding AddMapFlipControlCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/mapFlipMenuItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="mapExchangeControlToolStripMenuItem" Header="{resx:Localize MainFrame_mapExchangeControlToolStripMenuItem_Text}"
                                  Command="{Binding AddMapExchangeControlCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/mapExchangeControlItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="mapExchangeSeparateToolStripMenuItem" Header="{resx:Localize MainFrame_mapExchangeSeparateToolStripMenuItem_Text}"
                                  Command="{Binding AddMapExchangeSeparateCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/mapExchangeSeparateItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- Add Variation (image + text) -->
            <Button x:Name="addVariationToolStripButton" Padding="2,2"
                    Command="{Binding AddVariationCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/addVariation.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_addVariationToolStripButton_Text}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Special Items dropdown (image + text, click opens flyout menu) -->
            <Button x:Name="specialItemToolStripMenu" Padding="2,2">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Image Source="/Assets/Toolbar/specialItem.png" Width="16" Height="16"/>
                    <TextBlock Text="{resx:Localize MainFrame_specialItemToolStripMenu_Text}"
                               VerticalAlignment="Center"/>
                    <PathIcon Data="M1939 486L2029 576L1024 1581L19 576L109 486L1024 1401L1939 486Z"
                             Width="8" Height="8" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout  Placement="BottomEdgeAlignedLeft">
                        <MenuItem x:Name="mapIssuePointToolStripMenuItem" Header="{resx:Localize MainFrame_mapIssuePointToolStripMenuItem_Text}"
                                  Command="{Binding AddMapIssueCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/mapIssuePointItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="mandatoryCrossingPointToolStripMenuItem" Header="{resx:Localize MainFrame_mandatoryCrossingPointToolStripMenuItem_Text}"
                                  Command="{Binding AddMandatoryCrossingCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/mandatoryCrossingPointItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="optionalCrossingPointToolStripMenuItem" Header="{resx:Localize MainFrame_optionalCrossingPointToolStripMenuItem_Text}"
                                  Command="{Binding AddOptCrossingCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/optionalCrossingPointItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="outOfBoundsToolStripMenuItem" Header="{resx:Localize MainFrame_outOfBoundsToolStripMenuItem_Text}"
                                  Command="{Binding AddOutOfBoundsCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/outOfBoundsItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="dangerousToolStripMenuItem" Header="{resx:Localize MainFrame_dangerousToolStripMenuItem_Text}"
                                  IsVisible="{Binding IsVisibleDangerousArea}"
                                  Command="{Binding AddDangerousCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/dangerousItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="constructionToolStripMenuItem" Header="{resx:Localize MainFrame_constructionToolStripMenuItem_Text}"
                                  Command="{Binding AddConstructionCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/specialItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="waterLocationToolStripMenuItem" Header="{resx:Localize MainFrame_waterLocationToolStripMenuItem_Text}"
                                  Command="{Binding AddWaterCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/waterLocationItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="firstAidLocationToolStripMenuItem" Header="{resx:Localize MainFrame_firstAidLocationToolStripMenuItem_Text}"
                                  Command="{Binding AddFirstAidCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/firstAidLocationItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="forbiddenRouteMarkingToolStripMenuItem" Header="{resx:Localize MainFrame_forbiddenRouteMarkingToolStripMenuItem_Text}"
                                  Command="{Binding AddForbiddenCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/forbiddenRouteMarkingItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="boundaryToolStripMenuItem" Header="{resx:Localize MainFrame_boundaryToolStripMenuItem_Text}"
                                  Command="{Binding AddBoundaryCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/boundaryItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="registrationMarkToolStripMenuItem" Header="{resx:Localize MainFrame_registrationMarkToolStripMenuItem_Text}"
                                  Command="{Binding AddRegMarkCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/registrationMarkItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem x:Name="whiteOutToolStripMenuItem" Header="{resx:Localize MainFrame_whiteOutToolStripMenuItem_Text}"
                                  Command="{Binding AddWhiteOutCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/whiteOutItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="textToolStripMenuItem" Header="{resx:Localize MainFrame_textToolStripMenuItem_Text}"
                                  Command="{Binding AddTextCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/textItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="imageToolStripMenuItem" Header="{resx:Localize MainFrame_imageToolStripMenuItem_Text}"
                                  Command="{Binding AddImageCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/imageItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="lineToolStripMenuItem" Header="{resx:Localize MainFrame_lineToolStripMenuItem_Text}"
                                  Command="{Binding AddLineCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/lineItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="rectangleToolStripMenuItem" Header="{resx:Localize MainFrame_rectangleToolStripMenuItem_Text}"
                                  Command="{Binding AddRectangleCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/rectangleItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="ellipseToolStripMenuItem" Header="{resx:Localize MainFrame_ellipseToolStripMenuItem_Text}"
                                  Command="{Binding AddEllipseCommand}">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Toolbar/ellipseItem.png" Width="16" Height="16"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
            <Separator Width="1" Margin="2,2"/>

            <!-- Add Bend (image only) -->
            <Button x:Name="addBendToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_addBendToolStripButton_ToolTipText}"
                    Padding="2,2"
                    Command="{Binding AddBendCommand}">
                <Image Width="16" Height="16"
                       Source="{Binding IsEffectivelyEnabled,
                                RelativeSource={RelativeSource Self},
                                Converter={x:Static avutil:DisabledImageConverter.Instance},
                                ConverterParameter=/Assets/Toolbar/addBend.png}"/>
            </Button>

            <!-- Add Gap (image only) -->
            <Button x:Name="addGapToolStripButton"
                    ToolTip.Tip="{resx:Localize MainFrame_addGapToolStripButton_ToolTipText}"
                    Command="{Binding AddGapCommand}"
                    Padding="2,2">
                <Image Source="/Assets/Toolbar/addGap.png" Width="16" Height="16"/>
            </Button>
        </StackPanel>

        <!-- ==================== COURSE TABS ==================== -->
        <!-- TabStrip for course selection. Tabs are bound to ViewModel tab names. -->
        <TabStrip x:Name="courseTabs" DockPanel.Dock="Top" 
                  Theme="{DynamicResource CardTabStrip}"
                  ItemsSource="{Binding TabNames}"
                  SelectedIndex="{Binding SelectedTabIndex}"
                  Background="#E0E0E0">
        </TabStrip>

        <!-- ==================== STATUS BAR ==================== -->
        <!-- Status bar at the bottom with status text, zoom controls, and coordinate display. -->
        <Grid x:Name="statusBar" DockPanel.Dock="Bottom" Height="26"
              ColumnDefinitions="*,Auto,Auto,Auto,Auto"
              Background="#F0F2F4">

            <!-- Status message (Spring = fills available space) -->
            <TextBlock x:Name="statusLabel" Grid.Column="0"
                       VerticalAlignment="Center" Margin="4,0"
                       TextTrimming="WordEllipsis"
                       Text="{Binding StatusBarText}"/>

            <Separator Grid.Column="1" Height="20" Width="1" Margin="2,2"/>

            <!-- Zoom percentage label -->
            <TextBlock x:Name="zoomAmountLabel" Grid.Column="2"
                       Text="{Binding MapZoomFactor, StringFormat='Zoom: {0:P0}'}"
                       VerticalAlignment="Center" Margin="4,0"/>

            <!-- Zoom slider (replaces WinForms ToolStripTrackBar) -->
            <Slider x:Name="zoomTracker" Grid.Column="3" Classes="statusBarSlider"
                    Width="140" Height="20" VerticalAlignment="Center"
                    Minimum="0" Maximum="100"
                    Value="{Binding ZoomSliderValue, Mode=TwoWay}"/>

            <!-- Coordinate display -->
            <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Margin="2,2,6,2"
                    CornerRadius="2" Padding="4,0">
                <TextBlock x:Name="locationDisplay"
                           Text="{Binding StatusBarLocationDisplay}"
                           VerticalAlignment="Center" MinWidth="120"/>
            </Border>
        </Grid>

        <!-- ==================== MAIN CONTENT AREA ==================== -->
        <!-- Horizontal split: left panel (descriptions/selection) | right panel (map viewer).
             Replaces WinForms splitContainer. Left panel is fixed width. -->
        <Grid x:Name="splitContainer" ColumnDefinitions="250,Auto,*">

            <!-- === LEFT PANEL (splitDescription equivalent) === -->
            <!-- Vertical split: top (description/topology) | bottom (selection panel).
                 Replaces WinForms splitDescription. Bottom panel is fixed height. -->
            <Grid Grid.Column="0" RowDefinitions="*,Auto,200" >

                <!-- Description/Topology area with radio button toggle -->
                <Grid x:Name="leftColumnPanel" Grid.Row="0" Background="White" ClipToBounds="True"
                      RowDefinitions="*,Auto">

                    <!-- Panel that overlays descriptionControl and panelTopology.
                         In WinForms, radio buttons toggle visibility between these two. -->
                    <Panel x:Name="panelDescriptionAndTopology" Grid.Row="0">

                        <!-- 
                             WinForms type: PurplePen.DescriptionControl
                             Displays the IOF course description table (control descriptions).
                             This is a custom control that renders the description grid,
                             supports selection, and fires Change/SelectedIndexChange events.
                        -->
                        <views:DescriptionViewer 
                            x:Name="descriptionViewer"
                            DataContext="{Binding DescriptionViewerViewModel}"
                        />

                        <!-- Topology view panel (hidden by default, shown when radio button selected) -->
                        <Grid x:Name="panelTopology" IsVisible="False"
                              ColumnDefinitions="*,Auto">

                            <!-- PLACEHOLDER: mapViewerTopology
                                 WinForms type: PurplePen.MapView.MapViewer
                                 Displays the topology/ordering view of the course.
                                 Configured with: ConstrainedScrolling=PinTop, MaxZoom=1,
                                 MouseWheel=Scroll, MiddleButtonAutoDrag=false.
                                 TODO: Implement as a custom Avalonia control sharing
                                 the MapViewer rendering infrastructure. -->
                            <Border x:Name="mapViewerTopology" Grid.Column="0"
                                    Background="White" BorderBrush="LightGray" BorderThickness="1">
                                <TextBlock Text="[mapViewerTopology placeholder]"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="Gray" FontStyle="Italic"/>
                            </Border>

                            <!-- Vertical scroll bar for topology view -->
                            <ScrollBar x:Name="topologyScrollBar" Grid.Column="1"
                                       Orientation="Vertical"
                                       AllowAutoHide="False"
                                       Minimum="0" Maximum="100" ViewportSize="20"/>
                        </Grid>
                    </Panel>

                    <!-- Radio buttons to toggle between Descriptions and Topology/Ordering views -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,*"
                          Background="#f5f5f5" >
                        <Grid.Styles>
                            <Style Selector="RadioButton:not(:checked)">
                                <Setter Property="Padding" Value="6,3"/>
                            </Style>
                            <Style Selector="RadioButton:checked">
                                <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey4}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Grid.Styles>
                        <RadioButton x:Name="radioButtonDescriptions" Grid.Column="0"
                                     Theme="{DynamicResource ButtonRadioButton}"
                                     Classes="Small"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Content="{resx:Localize MainFrame_radioButtonDescriptions_Text}"
                                     IsChecked="True"/>
                        <RadioButton x:Name="radioButtonTopology" Grid.Column="1"
                                     Theme="{DynamicResource ButtonRadioButton}"
                                     Classes="Small"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Center"
                                     Content="{resx:Localize MainFrame_radioButtonTopology_Text}"/>
                    </Grid>
                </Grid>

                <!-- GridSplitter between description area and selection panel -->
                <GridSplitter Grid.Row="1" Height="4" ResizeDirection="Rows" Padding="0 2 -2 2"/>

                <!-- SelectionPanel
                     Displays context-sensitive selection controls (properties panel).
                     Dynamically populated with controls based on the current selection
                     (control properties, leg properties, special object properties, etc.).
                     Background is white. Controls flow vertically. -->

                    <views:SelectionPanel Grid.Row="2"
                                          SelectionDescription="{Binding SelectedObjectDescription}"/>
            </Grid>

            <!-- GridSplitter between left and right panels -->
            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" Padding="2 0"/>

            <!-- === RIGHT PANEL (map viewer area) === -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">

                <!-- Course part banner (top of map area) — shows course parts, variations, properties -->
                <resx:CoursePartBanner x:Name="coursePartBanner" 
                                       Grid.Row="0" Grid.ColumnSpan="2"
                                       DataContext="{Binding CoursePartBannerViewModel}"/>

                <!-- MapViewer
                     WinForms type: PurplePen.MapView.MapViewer
                     The main map display control. This is the largest and most complex custom control.
                     Configured with: ConstrainedScrolling=KeepSome, MaxZoom=100,
                     MouseWheel=Zoom, MiddleButtonAutoDrag=true, HoverDelay=400ms.
                     Renders the orienteering map with course overlays using MapDisplay.
                     Handles mouse events for course editing (adding controls, moving items, etc.).
                     Scroll bars are external (horizScroll, vertScroll below). -->
                <resx:MapViewer
                    x:Name="mapViewer"
                    Grid.Row="1" Grid.Column="0"
                    MapDisplay="{Binding MapDisplay}"
                    MapHighlights="{Binding MapHighlights}"
                    FancyMouseActivity="MapViewer_MouseActivity"
                    MouseLocation="{Binding MouseLocationInMap, Mode=OneWayToSource}"
                    ZoomFactor="{Binding MapZoomFactor, Mode=TwoWay}"
                />

                <!-- Vertical scroll bar for map viewer -->
                <ScrollBar x:Name="vertScroll" Grid.Row="1" Grid.Column="1"
                           Orientation="Vertical"
                           AllowAutoHide="False"
                           Minimum="0" Maximum="100" ViewportSize="20"/>

                <!-- Horizontal scroll bar for map viewer -->
                <ScrollBar x:Name="horizScroll" Grid.Row="2" Grid.Column="0"
                           Orientation="Horizontal"
                           AllowAutoHide="False"
                           Minimum="0" Maximum="100" ViewportSize="20"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
