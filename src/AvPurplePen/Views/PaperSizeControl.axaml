<!--
    PaperSizeControl.axaml

    Reusable control for choosing a paper size (standard or user-defined),
    margin, and orientation. The width/height/margin are exposed in hundredths
    of an inch via the PaperWidth / PaperHeight / PaperMargin styled properties;
    Landscape is a bool. Values are displayed in mm or inches according to the
    current culture.

    Migrated from WinForms PurplePen/PaperSizeControl.cs. Reused by the New
    Event wizard's paper-size page (and, in future, SetPrintAreaDialog).
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:resx="using:AvPurplePen"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="280" d:DesignHeight="150"
             x:Class="AvPurplePen.Views.PaperSizeControl">

    <!-- Orientation is chosen with two side-by-side, mutually-exclusive
         "buttons" (still RadioButtons under the hood, so GroupName handles the
         exclusion and the existing code-behind wiring is unchanged). Each shows
         an image with the Portrait/Landscape label below it; the selected one
         gets an accent border and a light highlight. -->
    <UserControl.Styles>
        <Style Selector="RadioButton.orientation">
            <Setter Property="Padding" Value="0"/>
            <!-- Fixed width so the Portrait and Landscape buttons are identical
                 in size despite differing image shapes and label lengths. -->
            <Setter Property="Width" Value="86"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{DynamicResource InputBackground}"
                            BorderBrush="{DynamicResource DarkGreyBorder}"
                            BorderThickness="2"
                            CornerRadius="4"
                            Padding="4,2">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.orientation:pointerover /template/ Border#PART_Border">
            <Setter Property="BorderBrush" Value="#3399FF"/>
        </Style>
        <Style Selector="RadioButton.orientation:checked /template/ Border#PART_Border">
            <Setter Property="BorderBrush" Value="#0066CC"/>
            <Setter Property="Background" Value="#E6F0FA"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
          RowDefinitions="Auto,Auto,Auto,Auto"
          HorizontalAlignment="Left">

        <Grid.Styles>
            <Style Selector="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>
            <Style Selector="NumericUpDown">
                <Setter Property="Width" Value="90"/>
                <Setter Property="Margin" Value="0,3,4,3"/>
            </Style>
        </Grid.Styles>

        <!-- Row 0: paper size combo -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="{resx:Localize PaperSizeControl_labelPaper_Text}"/>
        <ComboBox x:Name="comboBoxPaperSize"
                  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5"
                  Margin="0,3,0,3"
                  HorizontalAlignment="Stretch"
                  SelectionChanged="ComboBoxPaperSize_SelectionChanged"/>

        <!-- Row 1: width and height -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="{resx:Localize PaperSizeControl_labelWidth_Text}"/>
        <NumericUpDown x:Name="upDownWidth"
                       Grid.Row="1" Grid.Column="1"
                       ValueChanged="UpDown_ValueChanged"/>
        <TextBlock x:Name="labelUnitsWidth" Grid.Row="1" Grid.Column="2"/>

        <TextBlock Grid.Row="1" Grid.Column="3"
                   Text="{resx:Localize PaperSizeControl_labelHeight_Text}"/>
        <NumericUpDown x:Name="upDownHeight"
                       Grid.Row="1" Grid.Column="4"
                       ValueChanged="UpDown_ValueChanged"/>
        <TextBlock x:Name="labelUnitsHeight" Grid.Row="1" Grid.Column="5"/>

        <!-- Row 2: margin -->
        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                   Text="{resx:Localize PaperSizeControl_labelMargin_Text}"/>
        <NumericUpDown x:Name="upDownMargin"
                       Grid.Row="2" Grid.Column="4"
                       ValueChanged="UpDown_ValueChanged"/>
        <TextBlock x:Name="labelUnitsMargin" Grid.Row="2" Grid.Column="5"/>

        <!-- Row 3: orientation (two image buttons, see UserControl.Styles) -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6"
                    Orientation="Horizontal" Spacing="10" Margin="0,8,0,0"
                    HorizontalAlignment="Center">
            <RadioButton x:Name="radioPortrait"
                         Classes="orientation"
                         GroupName="Orientation"
                         IsCheckedChanged="Orientation_Changed">
                <StackPanel Orientation="Vertical" Spacing="0">
                    <Image Source="/Assets/Images/Portrait.png"
                           Width="34" Height="34"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                    <TextBlock Text="{resx:Localize PaperSizeControl_checkBoxPortrait_Text}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="radioLandscape"
                         Classes="orientation"
                         GroupName="Orientation"
                         IsCheckedChanged="Orientation_Changed">
                <StackPanel Orientation="Vertical" Spacing="0">
                    <Image Source="/Assets/Images/Landscape.png"
                           Width="34" Height="34"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                    <TextBlock Text="{resx:Localize PaperSizeControl_checkBoxLandscape_Text}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>
    </Grid>
</UserControl>
