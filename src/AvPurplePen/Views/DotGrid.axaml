<!--
    DotGrid.axaml
    Grid control that displays togglable filled circles in a grid of squares.
    Clicking a grid square toggles the dot on/off.
    Migrated from WinForms PurplePen/DotGrid.cs.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="200" d:DesignHeight="200"
             x:Class="AvPurplePen.Views.DotGrid" />
