<!--
    MoveAllControlsDialog.axaml

    Move All Controls dialog. A short description followed by four mutually
    exclusive radio buttons that choose how every control on the map is moved:
    move only, move and scale, move and rotate, or move, scale, and rotate.
    The choice is read back from the ViewModel's Action after OK.

    Migrated from WinForms PurplePen/MoveAllControls.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.MoveAllControlsDialog"
        Classes="dialog"
        x:DataType="vm:MoveAllControlsDialogViewModel"
        Title="{resx:Localize MoveAllControls_Text}"
        Icon="/Assets/transparent.ico"
        d:DesignWidth="420" d:DesignHeight="240"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:MoveAllControlsDialogViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- OK / Cancel buttons at the bottom -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button x:Name="okButton"
                    Content="{resx:Localize OKButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button x:Name="cancelButton"
                    Content="{resx:Localize CancelButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <StackPanel Spacing="12">

            <TextBlock x:Name="labelDescription"
                       Text="{resx:Localize MoveAllControls_labelDescription_Text}"
                       TextWrapping="Wrap"/>

            <StackPanel Spacing="6" Margin="0,4,0,0">
                <RadioButton x:Name="radioButtonMove"
                             GroupName="MoveAction"
                             Content="{resx:Localize MoveAllControls_radioButtonMove_Text}"
                             IsChecked="{Binding IsMove, Mode=TwoWay}"/>
                <RadioButton x:Name="radioButtonMoveAndScale"
                             GroupName="MoveAction"
                             Content="{resx:Localize MoveAllControls_radioButtonMoveAndScale_Text}"
                             IsChecked="{Binding IsMoveScale, Mode=TwoWay}"/>
                <RadioButton x:Name="radioButtonMoveAndRotate"
                             GroupName="MoveAction"
                             Content="{resx:Localize MoveAllControls_radioButtonMoveAndRotate_Text}"
                             IsChecked="{Binding IsMoveRotate, Mode=TwoWay}"/>
                <RadioButton x:Name="radioButtonMoveRotateScale"
                             GroupName="MoveAction"
                             Content="{resx:Localize MoveAllControls_radioButtonMoveRotateScale_Text}"
                             IsChecked="{Binding IsMoveRotateScale, Mode=TwoWay}"/>
            </StackPanel>

        </StackPanel>

    </DockPanel>
</Window>
