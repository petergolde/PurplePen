<!--
    PrintDescriptionsDialog.axaml

    Print Descriptions dialog (also serves as "Create PDF of Descriptions"
    when IsPdfCreation is true — the Printer row is hidden, the OK button
    reads "Create PDF", and the window title changes).

    Layout:
      * Output group (printer + paper + margins) at the top, full width.
      * Below it, two columns: Courses on the left, Copies + Appearance
        stacked on the right.
      * Preview / Print / Cancel buttons at the bottom.

    The Change Margins button opens the Page Setup dialog (bound to a command).
    The Change Printer and Preview buttons are wired but not yet implemented —
    clicking them is a no-op for now.

    Migrated from WinForms PurplePen/PrintDescriptions.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:views="using:AvPurplePen.Views"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.PrintDescriptionsDialog"
        Classes="dialog"
        x:DataType="vm:PrintDescriptionsDialogViewModel"
        Title="{resx:Localize PrintDescriptions_Text}"
        Icon="/Assets/transparent.ico"
        d:DesignWidth="660" d:DesignHeight="500"
        Width="660" Height="500"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:PrintDescriptionsDialogViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Bottom row: Preview / Print / Cancel. Print button label swaps
             between "Print" and "Create PDF" via two overlapping buttons
             whose visibility tracks IsPdfCreation. -->
        <Grid DockPanel.Dock="Bottom"
              ColumnDefinitions="Auto,*,Auto,Auto"
              Margin="0,12,0,0">
            <Button x:Name="previewButton"
                    Grid.Column="0"
                    Content="{resx:Localize PrintDescriptions_previewButton_Text}"
                    Width="120"
                    HorizontalContentAlignment="Center"
                    IsVisible="{Binding IsPreviewVisible}"
                    Click="PreviewButton_Click"/>

            <!-- Print (only when !IsPdfCreation) -->
            <Button x:Name="printButton"
                    Grid.Column="2"
                    Content="{resx:Localize PrintDescriptions_printButton_Text}"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    IsVisible="{Binding !IsPdfCreation}"
                    Margin="0,0,8,0"
                    Click="PrintButton_Click"/>

            <!-- Create PDF (only when IsPdfCreation) — same Grid.Column so
                 it overlays the Print button. -->
            <Button x:Name="createPdfButton"
                    Grid.Column="2"
                    Content="{x:Static resx:UIText.MiscText_CreatePdf}"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    IsVisible="{Binding IsPdfCreation}"
                    Margin="0,0,8,0"
                    Click="PrintButton_Click"/>

            <Button x:Name="cancelButton"
                    Grid.Column="3"
                    Content="{resx:Localize PrintDescriptions_cancelButton_Text}"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </Grid>

        <!-- Output group at the top, full width: printer (conditional) +
             paper size + orientation + margins + Change Margins button. -->
        <HeaderedContentControl DockPanel.Dock="Top"
                                Header="{resx:Localize PrintDescriptions_printerGroup_Text}"
                                Padding="8"
                                Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,8,*,8,Auto"
                  RowDefinitions="Auto,4,Auto,4,Auto,4,Auto">

                <!-- Row 0: Printer (hidden in PDF mode) -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{resx:Localize PrintDescriptions_printerLabel_Text}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsPrinterVisible}"/>
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="{Binding PrinterNameDisplay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding IsPrinterVisible}"/>
                <Button x:Name="printerChange"
                        Grid.Row="0" Grid.Column="4"
                        Classes="Small"
                        Content="{resx:Localize PrintDescriptions_printerChange_Text}"
                        IsVisible="{Binding IsPrinterVisible}"
                        Click="PrinterChange_Click"/>

                <!-- Row 2: Paper size -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{resx:Localize PrintDescriptions_paperSizeLabel_Text}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="2"
                           Text="{Binding PaperSizeDisplay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Row 4: Orientation -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{resx:Localize PrintDescriptions_orientationLabel_Text}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="4" Grid.Column="2"
                           Text="{Binding OrientationDisplay}"
                           VerticalAlignment="Center"/>

                <!-- Row 6: Margins + Change Margins button -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="{resx:Localize PrintDescriptions_marginsLabel_Text}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="6" Grid.Column="2"
                           Text="{Binding MarginsDisplay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button x:Name="marginChange"
                        Grid.Row="6" Grid.Column="4"
                        Classes="Small"
                        Content="{resx:Localize PrintDescriptions_marginChange_Text}"
                        Command="{Binding ChangeMarginsCommand}"/>
            </Grid>
        </HeaderedContentControl>

        <!-- Two columns below the Output group: Courses on the left,
             Copies + Appearance stacked on the right. -->
        <Grid ColumnDefinitions="*,12,*">

            <!-- === Left: Courses === -->
            <HeaderedContentControl Grid.Column="0"
                                    Header="{resx:Localize PrintDescriptions_coursesGroupBox_Text}"
                                    Padding="8,10,8,8">
                <views:CourseSelector x:Name="courseSelector"
                                      EventDB="{Binding EventDB}"
                                      ShowAllControls="True"
                                      ShowCourseParts="False"
                                      ShowVariationChooser="True"/>
            </HeaderedContentControl>

            <!-- === Right: Copies + Appearance === -->
            <StackPanel Grid.Column="2" Spacing="8">

                <!-- Copies group: "Print:" + combo, then below it (still in
                     this right column) the per-course description count
                     NumericUpDown + label. -->
                <HeaderedContentControl Header="{resx:Localize PrintDescriptions_copiesGroupBox_Text}"
                                        Padding="8,10,8,8">
                    <Grid ColumnDefinitions="Auto,8,*"
                          RowDefinitions="Auto,4,Auto">

                        <!-- "Print:" + copies combo -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{resx:Localize PrintDescriptions_whatToPrintLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="copiesCombo"
                                  Grid.Row="0" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="{Binding CopiesIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_copiesCombo_Items}"/>
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_copiesCombo_Items1}"/>
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_copiesCombo_Items2}"/>
                        </ComboBox>

                        <!-- Below the combo, a compact NumericUpDown sitting
                             flush against the "descriptions per course"
                             label. Spans the row so the StackPanel can
                             shrink-wrap its content. -->
                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="1"
                                    Orientation="Horizontal"
                                    Spacing="6">
                            <NumericUpDown x:Name="descriptionsUpDown"
                                           Width="70"
                                           Minimum="1"
                                           Maximum="999"
                                           FormatString="0"
                                           Value="{Binding DescriptionCount, Mode=TwoWay}"
                                           IsEnabled="{Binding IsDescriptionCountEnabled}"/>
                            <TextBlock x:Name="descriptionsLabel"
                                       Text="{resx:Localize PrintDescriptions_descriptionsLabel_Text}"
                                       VerticalAlignment="Center"
                                       IsEnabled="{Binding IsDescriptionCountEnabled}"/>
                        </StackPanel>
                    </Grid>
                </HeaderedContentControl>

                <!-- Appearance group (described as "layoutGroup" in WinForms) -->
                <HeaderedContentControl Header="{resx:Localize PrintDescriptions_layoutGroup_Text}"
                                        Padding="8,10,8,8">
                    <Grid ColumnDefinitions="Auto,8,*"
                          RowDefinitions="Auto,4,Auto">

                        <!-- Description type + combo -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{resx:Localize PrintDescriptions_descriptionTypeLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="descriptionKindCombo"
                                  Grid.Row="0" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="{Binding DescriptionKindIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_descriptionKindCombo_Items}"/>
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_descriptionKindCombo_Items1}"/>
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_descriptionKindCombo_Items2}"/>
                            <ComboBoxItem Content="{resx:Localize PrintDescriptions_descriptionKindCombo_Items3}"/>
                        </ComboBox>

                        <!-- Line size: label + NumericUpDown + "mm", all
                             flush together. The StackPanel shrink-wraps so
                             "mm" sits right after the NumericUpDown rather
                             than at the right edge of the group. -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{resx:Localize PrintDescriptions_lineSizeLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="2" Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="4">
                            <NumericUpDown x:Name="boxSizeUpDown"
                                           Width="70"
                                           Minimum="1"
                                           Maximum="50"
                                           Increment="0.1"
                                           FormatString="0.0"
                                           Value="{Binding BoxSize, Mode=TwoWay}"/>
                            <TextBlock Text="{resx:Localize PrintDescriptions_mmSuffixLabel_Text}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </HeaderedContentControl>

            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
