<!--
    ChangeSpecialCoursesDialog.axaml
    Dialog for choosing which courses a special object (text line, rectangle, etc.)
    is displayed on. Contains a label, a CourseSelector control, and OK/Cancel buttons.
    Migrated from WinForms PurplePen/ChangeSpecialCourses.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:views="using:AvPurplePen.Views"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.ChangeSpecialCoursesDialog"
        Classes="dialog"
        x:DataType="vm:ChangeSpecialCoursesDialogViewModel"
        Title="{resx:Localize ChangeSpecialCourses_Text}"
        Icon="/Assets/transparent.ico"
        d:DesignWidth="311" d:DesignHeight="289"
        Width="311" Height="320"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:ChangeSpecialCoursesDialogViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- OK / Cancel buttons at the bottom -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="okButton"
                    Content="{resx:Localize OKButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button x:Name="cancelButton"
                    Content="{resx:Localize CancelButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Instruction label at the top -->
        <TextBlock DockPanel.Dock="Top"
                   x:Name="changeDisplayedCoursesLabel"
                   Text="{resx:Localize ChangeSpecialCourses_changeDisplayedCoursesLabel_Text}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <!-- Course selector fills remaining space -->
        <views:CourseSelector x:Name="courseSelector"/>

    </DockPanel>

</Window>
