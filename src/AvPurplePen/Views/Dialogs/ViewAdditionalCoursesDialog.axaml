<!--
    ViewAdditionalCoursesDialog.axaml
    Dialog for choosing additional courses to view alongside the current course.
    Contains an instruction label, a CourseSelector control, and OK/Cancel buttons.
    Migrated from WinForms PurplePen/ViewAdditionalCourses.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:views="using:AvPurplePen.Views"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.ViewAdditionalCoursesDialog"
        Classes="dialog"
        x:DataType="vm:ViewAdditionalCoursesDialogViewModel"
        Title="{resx:Localize ViewAdditionalCourses_Text}"
        Icon="/Assets/transparent.ico"
        d:DesignWidth="290" d:DesignHeight="380"
        Width="290" Height="380"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:ViewAdditionalCoursesDialogViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- OK / Cancel buttons at the bottom -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="okButton"
                    Content="{resx:Localize OKButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button x:Name="cancelButton"
                    Content="{resx:Localize CancelButton}"
                    Width="85"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Instruction label at the top. The localized text is a format
             string with a {0} placeholder for the current course name, so it
             must use x:Static (a Binding from {resx:Localize} can't be used in
             StringFormat). Live language switching is not needed here. -->
        <TextBlock DockPanel.Dock="Top"
                   x:Name="labelInstructions"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
            <TextBlock.Text>
                <Binding Path="CourseName"
                         StringFormat="{x:Static resx:UIText.ViewAdditionalCourses_labelInstructions_Text}"/>
            </TextBlock.Text>
        </TextBlock>

        <!-- Course selector fills remaining space -->
        <views:CourseSelector x:Name="courseSelector"/>

    </DockPanel>

</Window>
