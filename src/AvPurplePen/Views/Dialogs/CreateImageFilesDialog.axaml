<!--
    CreateImageFilesDialog.axaml

    Dialog for exporting courses as PNG / JPEG / GIF image files. Layout is
    the same shape as CreateOcadFilesDialog: CourseSelector on the left,
    Output (file format / DPI / world file / color model / include base map /
    file name prefix) and Folder (3 radio buttons + optional folder picker)
    groups on the right, Create/Cancel buttons at the bottom.

    Migrated from WinForms PurplePen/CreateImageFiles.cs.
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:views="using:AvPurplePen.Views"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AvPurplePen.Views.CreateImageFilesDialog"
        Classes="dialog"
        x:DataType="vm:CreateImageFilesDialogViewModel"
        Title="{resx:Localize CreateImageFiles_Text}"
        Icon="/Assets/transparent.ico"
        d:DesignWidth="620" d:DesignHeight="420"
        Width="620" Height="420"
        CanResize="True"
        CanMinimize="False"
        CanMaximize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:CreateImageFilesDialogViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">

        <!-- Create / Cancel buttons at the bottom -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="createButton"
                    Content="{resx:Localize CreateImageFiles_createButton_Text}"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    IsDefault="True"
                    Click="CreateButton_Click"/>
            <Button x:Name="cancelButton"
                    Content="{resx:Localize CreateImageFiles_cancelButton_Text}"
                    Width="100"
                    HorizontalContentAlignment="Center"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Main content: two columns. Left = courses, right = output + folder. -->
        <Grid ColumnDefinitions="*,12,*">

            <!-- === Left column: Courses group === -->
            <HeaderedContentControl Grid.Column="0"
                                    Header="{resx:Localize CreateImageFiles_coursesGroupBox_Text}"
                                    Padding="8,10,8,8">
                <views:CourseSelector x:Name="courseSelector"
                                      EventDB="{Binding EventDB}"
                                      ShowAllControls="True"
                                      ShowCourseParts="False"
                                      ShowVariationChooser="True"/>
            </HeaderedContentControl>

            <!-- === Right column: Output (top) + Folder (bottom) === -->
            <DockPanel Grid.Column="2">

                <!-- Output group: file format, DPI, world file, color model,
                     include base map, filename prefix. -->
                <HeaderedContentControl DockPanel.Dock="Top"
                                        Header="{resx:Localize CreateImageFiles_outputGroupBox_Text}"
                                        Padding="8"
                                        Margin="0,0,0,8">
                    <Grid ColumnDefinitions="Auto,8,*"
                          RowDefinitions="Auto,4,Auto,4,Auto,4,Auto,4,Auto,4,Auto">

                        <!-- Row 0: File format -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_fileFormatLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="fileFormatCombo"
                                  Grid.Row="0" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding AvailableFileFormats}"
                                  SelectedItem="{Binding SelectedFileFormat, Mode=TwoWay}"/>

                        <!-- Row 2: DPI (editable combo — accepts standard values + custom typed-in values) -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_dpiLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="comboBoxDpi"
                                  Grid.Row="2" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  IsEditable="True"
                                  ItemsSource="{Binding DpiOptions}"
                                  Text="{Binding DpiText, Mode=TwoWay}"/>

                        <!-- Row 4: World file -->
                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_label1_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="comboBoxWorldFile"
                                  Grid.Row="4" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  IsEnabled="{Binding WorldFileEnabled}"
                                  SelectedIndex="{Binding WorldFileIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxWorldFile_Items}"/>
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxWorldFile_Items1}"/>
                        </ComboBox>

                        <!-- Row 6: Color model -->
                        <TextBlock Grid.Row="6" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_labelColorModel_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="comboBoxColorModel"
                                  Grid.Row="6" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="{Binding ColorModelIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxColorModel_Items}"/>
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxColorModel_Items1}"/>
                        </ComboBox>

                        <!-- Row 8: Include (base map or just course) -->
                        <TextBlock Grid.Row="8" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_labelPrintBaseMap_Text}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="comboBoxPrintBaseMap"
                                  Grid.Row="8" Grid.Column="2"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="{Binding PrintBaseMapIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxPrintBaseMap_Items}"/>
                            <ComboBoxItem Content="{resx:Localize CreateImageFiles_comboBoxPrintBaseMap_Items1}"/>
                        </ComboBox>

                        <!-- Row 10: File name prefix -->
                        <TextBlock Grid.Row="10" Grid.Column="0"
                                   Text="{resx:Localize CreateImageFiles_fileNamePrefixLabel_Text}"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="filenamePrefixTextBox"
                                 Grid.Row="10" Grid.Column="2"
                                 Text="{Binding FilePrefix, Mode=TwoWay}"/>
                    </Grid>
                </HeaderedContentControl>

                <!-- Folder group: three radio buttons + folder picker -->
                <HeaderedContentControl Header="{resx:Localize CreateImageFiles_folderGroupBox_Text}"
                                        Padding="8">
                    <StackPanel Spacing="4">
                        <RadioButton x:Name="coursesDirectory"
                                     GroupName="OutputFolder"
                                     Content="{resx:Localize CreateImageFiles_coursesDirectory_Text}"
                                     IsChecked="{Binding UseFileDirectory, Mode=TwoWay}"/>
                        <RadioButton x:Name="mapDirectory"
                                     GroupName="OutputFolder"
                                     Content="{resx:Localize CreateImageFiles_mapDirectory_Text}"
                                     IsChecked="{Binding UseMapDirectory, Mode=TwoWay}"/>
                        <RadioButton x:Name="otherDirectory"
                                     GroupName="OutputFolder"
                                     Content="{resx:Localize CreateImageFiles_otherDirectory_Text}"
                                     IsChecked="{Binding UseOtherDirectory, Mode=TwoWay}"/>

                        <!-- Other folder text box + Select folder button.
                             Only visible when the "Other folder" radio is selected. -->
                        <TextBox x:Name="otherDirectoryTextBox"
                                 Text="{Binding OutputDirectory, Mode=TwoWay}"
                                 IsVisible="{Binding IsOtherDirectoryVisible}"
                                 Margin="20,4,0,0"/>
                        <Button x:Name="selectOtherDirectoryButton"
                                Classes="Small"
                                Content="{resx:Localize CreateImageFiles_selectOtherDirectoryButton_Text}"
                                IsVisible="{Binding IsOtherDirectoryVisible}"
                                HorizontalAlignment="Right"
                                Click="SelectOtherDirectoryButton_Click"/>
                    </StackPanel>
                </HeaderedContentControl>
            </DockPanel>

        </Grid>

    </DockPanel>
</Window>
