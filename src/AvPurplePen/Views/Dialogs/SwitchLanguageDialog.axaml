<!--
    SwitchLanguageDialog.axaml

    A modal dialog that lets the user pick a UI language from a list.
    The DataContext is a SwitchLanguageViewModel, which holds the list
    of available languages and the currently selected one.

    OK and Cancel buttons close the dialog, returning true or false
    to the caller via Window.Close(result).
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PurplePen.ViewModels"
        xmlns:resx="using:AvPurplePen"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="350" d:DesignHeight="450"
        x:Class="AvPurplePen.Views.SwitchLanguageDialog"
        Classes="dialog"
        x:DataType="vm:SwitchLanguageDialogViewModel"
        Title="{x:Static resx:UIText.SwitchLanguageDialog_Title}"
        Width="350" Height="450"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SystemDecorations="Full">

    <!-- Design-time preview data -->
    <Design.DataContext>
        <vm:SwitchLanguageDialogViewModel/>
    </Design.DataContext>

    <!-- Main layout: list fills available space, buttons anchored at bottom -->
    <DockPanel Margin="16">

        <!-- Button row at the bottom -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button x:Name="okButton"
                    Content="{x:Static resx:UIText.OKButton}"
                    Width="80"
                    HorizontalContentAlignment="Center"
                    Click="OkButton_Click"
                    IsDefault="True"/>
            <Button x:Name="cancelButton"
                    Content="{x:Static resx:UIText.CancelButton}"
                    Width="80"
                    HorizontalContentAlignment="Center"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
        </StackPanel>

        <!-- Prompt label above the list -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{resx:Localize SwitchLanguageDialog_Prompt}"
                   Margin="0,0,0,8"/>

        <!-- Language list box fills the remaining space -->
        <ListBox x:Name="languageListBox"
                 ItemsSource="{Binding AvailableLanguages}"
                 SelectedItem="{Binding SelectedLanguage}"
                 DoubleTapped="LanguageListBox_DoubleTapped"
                 >
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LanguageItem">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding DisplayName}" 
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,1"/>
                        <TextBlock Text="{Binding Code}"
                                   Foreground="Gray"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>

</Window>
